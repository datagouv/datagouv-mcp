MCP_HOST=127.0.0.1
MCP_PORT="8000"
MCP_ENV="local"
DATAGOUV_API_ENV="prod"
LOG_LEVEL="INFO"

# Maximum file size (MB) that download_and_parse_resource will accept.
# CSV/JSONL files are streamed from disk with no RAM spike.
# JSON files require a full in-memory parse during normalisation to JSONL,
# so keep this conservative to avoid OOM on the server.
MAX_DOWNLOAD_SIZE_MB=100

# Matomo tracking
# MATOMO_SITE_ID="1"
# MATOMO_AUTH_TOKEN="1234567890"

# Sentry error and performance monitoring
# SENTRY_DSN="https://..."
# SENTRY_SAMPLE_RATE="1.0"
